# ============================================================================
# Database Configuration (Supabase Session Pooler)
# ============================================================================
DB_HOST=your-project.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.your-project-ref
DB_PASSWORD=your-db-password

# ============================================================================
# Global Scraper Configuration
# ============================================================================
SCRAPER_DELAY=2
MAX_RETRIES=3
MAX_NEW_PER_SCRAPER=100
LOG_LEVEL=INFO

# Shared Selenium delay range (seconds) — random wait before each portal load
SELENIUM_DELAY_MIN=4
SELENIUM_DELAY_MAX=9

# ============================================================================
# 1. Grants.gov
# ============================================================================
GRANTS_GOV_BASE_URL=https://www.grants.gov
GRANTS_GOV_API_URL=https://api.grants.gov/v1/api/search2
GRANTS_GOV_DETAIL_API_URL=https://api.grants.gov/v1/api/fetchOpportunity
GRANTS_GOV_DETAIL_PAGE_TIMEOUT=15
GRANTS_GOV_DETAIL_PAGE_RENDER_WAIT=3

# ============================================================================
# 2. SAM.gov  (get free API key at https://sam.gov/data-services/)
# ============================================================================
SAM_GOV_API_KEY=your-sam-gov-api-key
SAM_GOV_BASE_URL=https://sam.gov
SAM_GOV_API_URL=https://api.sam.gov/prod/opportunities/v2/search
# Daily API budget (search + description calls combined).
# Basic key = 10/day, Entity key = 1000/day, Federal key = 10000/day.
SAM_GOV_MAX_REQUESTS=10
SAM_GOV_OPP_DELAY=2.0
SAM_GOV_PAGE_DELAY=10.0

# ============================================================================
# 3. Duke Research Funding
# ============================================================================
DUKE_BASE_URL=https://researchfunding.duke.edu
DUKE_LISTING_URL=https://researchfunding.duke.edu/search-results?open=1&sort_bef_combine=deadline_ASC

# ============================================================================
# 4. California Grants Portal (CKAN API)
# ============================================================================
CA_GRANTS_API_URL=https://data.ca.gov/api/3/action/datastore_search_sql
CA_GRANTS_RESOURCE_ID=111c8c88-21f6-453c-ae2c-b4785a0624f5

# ============================================================================
# 5. The Grant Portal (TGP) — works without login
# ============================================================================
TGP_BASE_URL=https://www.thegrantportal.com
TGP_MAX_PAGES_PER_STATE=10
TGP_EMAIL=
TGP_PASSWORD=

# ============================================================================
# 6. Texas ESBD (Electronic State Business Daily)
# ============================================================================
TX_ESBD_BASE_URL=https://www.txsmartbuy.gov
TX_ESBD_GRANTS_MAX_PAGES=10
TX_ESBD_SOLICITATIONS_MAX_PAGES=15
TX_ESBD_PRESOLICITATIONS_MAX_PAGES=15

# ============================================================================
# 7. NC eVP (North Carolina Electronic Vendor Portal)
# ============================================================================
NC_EVP_BASE_URL=https://evp.nc.gov
NC_EVP_MAX_PAGES=50

# ============================================================================
# 8. GovernmentContracts.us (RFP aggregator)
# ============================================================================
GOVCONTRACTS_BASE_URL=https://www.governmentcontracts.us
GOVCONTRACTS_MAX_PAGES_PER_STATE=5

# ============================================================================
# 9. RFPMart (massive RFP aggregator — full descriptions public)
# ============================================================================
RFPMART_BASE_URL=https://www.rfpmart.com
RFPMART_MAX_PAGES=10
